generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Artist {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  aliases        Alias[]
  IgnoreGrouping IgnoreGrouping?
}

model Alias {
  id       Int    @id @default(autoincrement())
  name     String @unique
  artistId Int
  artist   Artist @relation(fields: [artistId], references: [id])
}

model IgnoreCanonicalization {
  id   Int    @id @unique @default(autoincrement())
  name String @unique(map: "IgnoreCanonicalization_name_key")
}

model IgnoreGrouping {
  id       Int     @id @default(autoincrement())
  name     String  @unique(map: "IgnoreGrouping_name_key")
  artistId Int?    @unique
  artist   Artist? @relation(fields: [artistId], references: [id])
}
