{
   "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "baseUrl": ".",
      "moduleResolution": "Bundler",
      "skipLibCheck": true,
      "paths": {
         "@/*": ["src/*"],
         "@/assets/*": ["public/Assets/*"]
      },
      "jsx": "react-jsx",
      "incremental": true,
      "lib": ["dom", "dom.iterable", "esnext"],
      "allowJs": true,
      "strict": true,
      "noEmit": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "isolatedModules": true,
      "plugins": [
         {
            "name": "next"
         }
      ]
   },
   "include": [
      "**/*.ts",
      "**/*.tsx",
      "next-env.d.ts",
      ".next/types/**/*.ts",
      "types/**/*.ts",
      ".next/dev/types/**/*.ts"
   ],
   "exclude": ["node_modules", "*.module.css"]
}
